[gd_resource type="Resource" script_class="RecipeCatalog" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/core/RecipeCatalog.gd" id="1"]

[resource]
script = ExtResource("1")
recipes = [{"description": "Compress common ore into durable industrial plating.", "id": "refine_metal_plates", "inputs": [{"item_id": "common_ore", "quantity": 5}], "name": "Metal Plate Refining", "outputs": [{"item_id": "metal_plates", "quantity": 2}], "station_types": ["industrial", "frontier"]}, {"description": "Refine crystalline feedstock into capacitor-ready modules.", "id": "refine_capacitor_units", "inputs": [{"item_id": "industrial_crystal", "quantity": 5}], "name": "Capacitor Unit Refining", "outputs": [{"item_id": "capacitor_units", "quantity": 2}], "station_types": ["research", "industrial"]}, {"description": "Stabilize volatile gas into shippable fuel cells.", "id": "refine_fuel_cells", "inputs": [{"item_id": "volatile_gas", "quantity": 5}], "name": "Fuel Cell Refining", "outputs": [{"item_id": "stabilized_fuel_cells", "quantity": 2}], "station_types": ["frontier", "industrial"]}, {"description": "Break down rare alloy into weapon-grade components.", "id": "refine_weapon_components", "inputs": [{"item_id": "rare_alloy", "quantity": 3}], "name": "Weapon Component Refining", "outputs": [{"item_id": "weapon_components", "quantity": 1}], "station_types": ["military", "industrial"]}, {"description": "Fuse alien tech and relic fragments into warp circuitry.", "id": "refine_warp_components", "inputs": [{"item_id": "alien_tech", "quantity": 2}, {"item_id": "ancient_relics", "quantity": 1}], "name": "Warp Component Refining", "outputs": [{"item_id": "warp_components", "quantity": 1}], "station_types": ["research"]}]
